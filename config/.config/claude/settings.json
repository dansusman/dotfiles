{
  "includeCoAuthoredBy": false,
  "permissions": {
    "deny": [
      "Bash(/Users/danielsusman/Applications/GitButler.app/Contents/MacOS/gitbutler-tauri log --json 2>/dev/null)",
      "Bash(head -50)"
    ],
    "defaultMode": "auto"
  },
  "model": "opus[1m]",
  "skillOverrides": {
    "apply-react-conventions": "off",
    "apply-redux-conventions": "off",
    "apply-testing-library-conventions": "off",
    "apply-vitest-conventions": "off",
    "auto-android-qa": "off",
    "build-notability-android": "off",
    "create-plan": "off",
    "fix-dependabot": "off",
    "oncall": "off",
    "run-qa-batch": "off",
    "test-notability-android": "off",
    "use-notability-android": "off",
    "use-notability-web": "off",
    "diagnose": "off",
    "find-skills": "off",
    "generate-beta-test-details": "off",
    "generate-whats-new": "off",
    "hunk-review": "off",
    "plannotator-annotate": "off",
    "plannotator-last": "off",
    "plannotator-review": "off"
  },
  "hooks": {
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/danielsusman/.config/claude/render-images-hook.sh"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "claude-notify-sound Notification"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "claude-notify-sound Stop"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash ~/.config/claude/statusline.sh"
  },
  "enabledPlugins": {
    "caveman@caveman": false,
    "clangd-lsp@claude-plugins-official": true,
    "swift-lsp@claude-plugins-official": true,
    "improve-claude-md@skills": false,
    "warp@claude-code-warp": false,
    "visual-explainer@visual-explainer-marketplace": false
  },
  "extraKnownMarketplaces": {
    "caveman": {
      "source": {
        "source": "github",
        "repo": "JuliusBrussee/caveman"
      }
    },
    "skills": {
      "source": {
        "source": "github",
        "repo": "humanlayer/skills"
      }
    },
    "claude-code-warp": {
      "source": {
        "source": "github",
        "repo": "warpdotdev/claude-code-warp"
      }
    },
    "visual-explainer-marketplace": {
      "source": {
        "source": "github",
        "repo": "nicobailon/visual-explainer"
      }
    }
  },
  "sandbox": {
    "enabled": false,
    "autoAllowBashIfSandboxed": true,
    "allowUnsandboxedCommands": false,
    "enableWeakerNetworkIsolation": true
  },
  "effortLevel": "medium",
  "tui": "fullscreen",
  "skipDangerousModePermissionPrompt": true,
  "theme": "light-daltonized",
  "editorMode": "vim",
  "preferredNotifChannel": "terminal_bell",
  "inputNeededNotifEnabled": true,
  "agentPushNotifEnabled": true,
  "skipAutoPermissionPrompt": true
}
