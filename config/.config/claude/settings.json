{
  "includeCoAuthoredBy": false,
  "permissions": {
    "deny": [
      "Bash(/Users/danielsusman/Applications/GitButler.app/Contents/MacOS/gitbutler-tauri log --json 2>/dev/null)",
      "Bash(head -50)"
    ]
  },
  "model": "opus[1m]",
  "hooks": {
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "claude-notify Notification"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "claude-notify PostToolUse"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "claude-notify PreToolUse"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "claude-notify Stop"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "claude-notify SubagentStop"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash ~/.claude/statusline.sh"
  },
  "enabledPlugins": {
    "caveman@caveman": true,
    "clangd-lsp@claude-plugins-official": true,
    "swift-lsp@claude-plugins-official": true,
    "improve-claude-md@skills": true
  },
  "extraKnownMarketplaces": {
    "caveman": {
      "source": {
        "source": "github",
        "repo": "JuliusBrussee/caveman"
      }
    },
    "skills": {
      "source": {
        "source": "github",
        "repo": "humanlayer/skills"
      }
    }
  },
  "skipDangerousModePermissionPrompt": true,
  "editorMode": "vim",
  "preferredNotifChannel": "terminal_bell",
  "effortLevel": "medium"
}
