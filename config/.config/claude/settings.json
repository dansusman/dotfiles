{
  "includeCoAuthoredBy": false,
  "permissions": {
    "deny": [
      "Bash(/Users/danielsusman/Applications/GitButler.app/Contents/MacOS/gitbutler-tauri log --json 2>/dev/null)",
      "Bash(head -50)"
    ]
  },
  "model": "opus[1m]",
  "hooks": {
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "claude-notify-sound Notification"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "claude-notify-sound Stop"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash ~/.config/claude/statusline.sh"
  },
  "enabledPlugins": {
    "caveman@caveman": true,
    "clangd-lsp@claude-plugins-official": true,
    "swift-lsp@claude-plugins-official": true,
    "improve-claude-md@skills": true,
    "warp@claude-code-warp": true,
    "visual-explainer@visual-explainer-marketplace": true
  },
  "extraKnownMarketplaces": {
    "caveman": {
      "source": {
        "source": "github",
        "repo": "JuliusBrussee/caveman"
      }
    },
    "skills": {
      "source": {
        "source": "github",
        "repo": "humanlayer/skills"
      }
    },
    "claude-code-warp": {
      "source": {
        "source": "github",
        "repo": "warpdotdev/claude-code-warp"
      }
    },
    "visual-explainer-marketplace": {
      "source": {
        "source": "github",
        "repo": "nicobailon/visual-explainer"
      }
    }
  },
  "effortLevel": "medium",
  "skipDangerousModePermissionPrompt": true,
  "theme": "light-daltonized",
  "editorMode": "vim",
  "preferredNotifChannel": "terminal_bell"
}
