#!/bin/bash
set -e

LOCALIZATION_DIR="${NOTABILITY_LOCALIZATION:-$HOME/Developer/notability/staging/Tools/Localization}"
REPO_ROOT=$(git -C "$LOCALIZATION_DIR" rev-parse --show-toplevel)
BRANCH=$(git -C "$REPO_ROOT" rev-parse --abbrev-ref HEAD)

if [[ ! "$BRANCH" =~ ^release/ ]]; then
    echo "Error: not on a release branch (current: $BRANCH). Bail."
    exit 1
fi

cd "$LOCALIZATION_DIR"
echo "Branch: $BRANCH"

echo "Running --strings-import..."
python3 localizer.py --strings-import

echo "Running --remove-unused..."
python3 localizer.py --remove-unused

echo "Done."
echo "Double check git diff app-db.txt"
