#!/bin/bash
set -e

LOCALIZATION_DIR="${NOTABILITY_LOCALIZATION:-$HOME/Developer/notability/staging/Tools/Localization}"
REPO_ROOT=$(git -C "$LOCALIZATION_DIR" rev-parse --show-toplevel)
BRANCH=$(git -C "$REPO_ROOT" rev-parse --abbrev-ref HEAD)

if [[ ! "$BRANCH" =~ ^susman/strings/ ]]; then
    echo "Error: not on a strings branch (current: $BRANCH). Bail."
    exit 1
fi

cd "$LOCALIZATION_DIR"

echo "Running --strings-export..."
python3 localizer.py --strings-export

cd "$REPO_ROOT"

echo ""
echo "=== Git status ==="
git status
echo ""
read -p "Commit all changes? [y/N] " confirm
[[ "$confirm" =~ ^[Yy]$ ]] || { echo "Aborted."; exit 1; }

git add -A
git commit -m "chore(strings): import gengo translations and export"

echo ""
echo "Done. Run: git push"
